DATABASE_URL=sqlite://database.db?mode=rwc
API_ADDR=127.0.0.1:8080
SEED_DEMO_DATA=0
DEMO_ADMIN_EMAIL=admin@example.test
# Set only in your local .env when SEED_DEMO_DATA=1. Do not commit real passwords.
# DEMO_ADMIN_PASSWORD=
# Local password reset testing only. Never enable in production.
PASSWORD_RESET_EXPOSE_TOKEN=0
# Password reset delivery. Use `log` locally and `smtp` in production.
PASSWORD_RESET_DELIVERY=log
# Optional URL used inside the recovery email. Example: https://app.example.com
# PASSWORD_RESET_PUBLIC_URL=
# Required when PASSWORD_RESET_DELIVERY=smtp.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=Barbearia Mestre
